digraph network {
    rankdir = "TB";
    node [shape=box, style=filled, fillcolor=white, fontsize=11];
    edge [fontsize=9];

    // External
    internet [label="Internet\nNBN 1000/100", shape=ellipse, fillcolor="#dbeafe"];

    // Gateway
    gw [label="gw\nGL-iNet GL-MT6000, OpenWrt\nWAN: 120.88.117.136/22\nLAN: 192.168.1.1/24\nWG: 172.16.1.1, 172.16.2.1", fillcolor="#fef3c7"];

    // Outer LAN (192.168.1.0/24)
    subgraph cluster_outer {
        label = "Outer LAN (192.168.1.0/24, untrusted)";
        style = dashed;
        fontsize = 10;

        gw2 [label="gw2\nOpenWrt CT on pve5\nWAN: 192.168.1.200\nLAN: 192.168.2.1/24\nMasquerade: ON", fillcolor="#fef3c7"];
        pve5_outer [label="pve5 vmbr4\n192.168.1.250", fillcolor="#e0e7ff"];
        mko_outer [label="mko eth1\n192.168.1.210", fillcolor="#e0e7ff"];
        jellyfin_outer [label="jellyfin eth1\n192.168.1.120\nDLNA", fillcolor="#e0e7ff"];
    }

    // Inner LAN (192.168.2.0/24)
    subgraph cluster_inner {
        label = "Inner LAN (192.168.2.0/24, secured)";
        style = filled;
        fillcolor = "#f0fdf4";
        fontsize = 10;

        cachyos [label="cachyos\n192.168.2.10\nworkstation", fillcolor="#bbf7d0"];
        pve5 [label="pve5\n192.168.2.25\nProxmox host", fillcolor="#e0e7ff"];
        pve_cluster [label="pve2-4\n192.168.2.22-24\nProxmox nodes", fillcolor="#e0e7ff"];
        pbs_cluster [label="pbs2-4\n192.168.2.32-34\nBackup servers", fillcolor="#e0e7ff"];
        mko [label="mko\n192.168.2.210\ncosmix mail server", fillcolor="#fecaca"];
        jellyfin [label="jellyfin\n192.168.2.120\nmedia", fillcolor="#e0e7ff"];
        ollama [label="ollama\n192.168.2.130\nLLM inference", fillcolor="#ddd6fe"];
    }

    // WireGuard mesh
    subgraph cluster_wg0 {
        label = "wg0 mesh (172.16.1.0/24)";
        style = dashed;
        fontsize = 10;
        color = "#6366f1";

        pixel [label="pixel\n172.16.1.2\nmobile", shape=ellipse, fillcolor="#fce7f3"];
        s76 [label="s76\n172.16.1.3", fillcolor="#e0e7ff"];
        pve1_ch [label="pve1-ch\n172.16.1.5\nSydney", fillcolor="#e0e7ff"];
        cherry [label="cherry\n172.16.1.7\n144.6.248.36", fillcolor="#e0e7ff"];
        mmc [label="mmc\n172.16.1.9\n203.25.132.25", fillcolor="#e0e7ff"];
    }

    // Corosync
    corosync [label="Corosync\n192.168.10.0/24\nair-gapped", shape=ellipse, fillcolor="#f3e8ff"];

    // Connections
    internet -> gw [label="eth1, 2.5G"];
    gw -> gw2 [label="br-lan"];
    gw -> pve5_outer;
    gw -> mko_outer;
    gw -> jellyfin_outer;

    gw2 -> cachyos;
    gw2 -> pve5;
    gw2 -> pve_cluster;
    gw2 -> pbs_cluster;
    gw2 -> mko;
    gw2 -> jellyfin;
    gw2 -> ollama;

    // Dual-homed
    pve5 -> pve5_outer [style=dashed, label="dual"];
    mko -> mko_outer [style=dashed, label="dual"];
    jellyfin -> jellyfin_outer [style=dashed, label="dual"];

    // WG mesh
    gw -> pixel [style=dashed, color="#6366f1", label="wg0"];
    gw -> s76 [style=dashed, color="#6366f1"];
    gw -> pve1_ch [style=dashed, color="#6366f1"];
    gw -> cherry [style=dashed, color="#6366f1"];
    gw -> mmc [style=dashed, color="#6366f1"];
    gw -> cachyos [style=dashed, color="#6366f1", label="wg0"];

    // Corosync
    pve5 -> corosync [style=dashed, color="#9333ea"];
    pve_cluster -> corosync [style=dashed, color="#9333ea"];
}
