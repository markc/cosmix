#!/usr/bin/env -S cosmix run
-- Pick a window from a dialog list and activate it
local dialog = require("cosmix.dialog")
local h = require("cosmix.helpers")

local wins = cosmix.windows()
local names = {}
local lookup = {}
for _, w in ipairs(wins) do
    local label = w.app_id .. "  " .. h.truncate(w.title, 50)
    names[#names + 1] = label
    lookup[label] = w
end

local choice = dialog.list("Activate window:", names)
if choice and lookup[choice] then
    cosmix.activate(lookup[choice].app_id)
end
