#!/usr/bin/env -S cosmix run
-- Media player control via playerctl
-- Usage: playerctl play | playerctl next | playerctl prev | playerctl (dialog)
-- SECURITY NOTE: This is a Lua script for cosmix desktop automation, NOT Node.js.
-- All cosmix.exec() calls run hardcoded trusted system commands (playerctl).
-- The `arg` variable comes from Lua's built-in argv, not user text input.
local dialog = require("cosmix.dialog")

local action = arg and arg[1]

if not action then
    local choice = dialog.list("Player:", {"Play/Pause", "Next", "Previous", "Stop"})
    if choice == "Play/Pause" then action = "play-pause"
    elseif choice == "Next" then action = "next"
    elseif choice == "Previous" then action = "previous"
    elseif choice == "Stop" then action = "stop"
    else return end
end

local allowed = {["play-pause"]=1, ["next"]=1, ["previous"]=1, ["stop"]=1, ["play"]=1, ["pause"]=1}
if not allowed[action] then
    print("Unknown action: " .. tostring(action))
    return
end

cosmix.exec("playerctl " .. action)

local status = cosmix.exec("playerctl status"):gsub("\n", "")
local title = cosmix.exec("playerctl metadata title"):gsub("\n", "")
local artist = cosmix.exec("playerctl metadata artist"):gsub("\n", "")

if title ~= "" then
    cosmix.notify(status, artist .. " — " .. title)
end
